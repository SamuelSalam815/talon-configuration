tab next: key(ctrl-tab)
tab last: key(ctrl-shift-tab)

sup: key(up)
doom: key(down)

yes: key(enter)

jump home: key(ctrl-home)
jump end: key(ctrl-end)

toy search: key(alt-space)
win search: key(super-s)

clear <number_small> left:
    key("backspace:{number_small}")

clear <number_small> right:
    key("delete:{number_small}")

clear left: key(backspace)
clear right: key(delete)
